{
  "global": [
    {
      "description": "Replace URLs with '[link]' to avoid reading out long strings",
      "type": "regex",
      "match": "https?://\\S+",
      "replace": "[link]"
    },
    {
      "description": "Drop markdown formatting characters",
      "type": "regex",
      "match": "[*_`#~>]",
      "replace": ""
    },
    {
      "description": "Strip common emojis",
      "type": "regex",
      "match": "[\\x{1F300}-\\x{1F9FF}]|[\\x{2600}-\\x{26FF}]|[\\x{2700}-\\x{27BF}]",
      "replace": ""
    },
    {
      "description": "Collapse any runs of whitespace",
      "type": "regex",
      "match": "\\s+",
      "replace": " "
    },
    {
      "description": "Parenthetical pauses",
      "type": "regex",
      "match": "([\\(\\)])",
      "replace": ",$1"
    },
    {
      "description": "Handle numbered lists prosody",
      "type": "regex",
      "match": "(?m)(^\\d+)\\. ",
      "replace": "$1, ",
      "pre_split": true
    },
    {
      "description": "Common tech acronyms",
      "type": "map",
      "map": {
      	"llama.cpp": "llama dot cpp",
      	"e.g.": "EG",
        "VRAM": "v ram",
        "DRAM": "d ram",
        "I/O": "eye oh",
        "TB": "terabytes",
        "GB": "gigabytes",
        "MB": "megabytes",
        "KB": "kilobytes",
        "/s ": " per second "
      }
    }
  ],
  "piper": [],
  "kokoro": []
}
